{
  "manifest_version": 3,
  "name": "Navi — Private Bookmark Dashboard",
  "version": "1.2",
  "description": "Private bookmark dashboard with read-only Chrome sync.",
  "permissions": [
    "bookmarks",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}